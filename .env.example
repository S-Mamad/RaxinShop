# Public site URL (no trailing slash) — required on Vercel for robots/sitemap/OG
NEXT_PUBLIC_SITE_URL=https://raxin-shop-r4aj.vercel.app

# Supabase (required for production order persistence on Vercel)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Admin panel (/hajiasal/admin)
ADMIN_PASSWORD=change_me_strong_password

# Customer auth (required in production)
AUTH_SESSION_SECRET=change_me_long_random_secret_min_32_chars
AUTH_TEST_PHONE=09123456789
AUTH_TEST_OTP=1234

# SMS provider (Kavenegar default, or ghasedak)
SMS_PROVIDER=kavenegar
SMS_API_KEY=
SMS_SENDER=

# Payment gateway (future — Zarinpal)
ZARINPAL_MERCHANT_ID=your_merchant_id
PAYMENT_GATEWAY_KEY=your_gateway_key

# Optional: rate limiting
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
