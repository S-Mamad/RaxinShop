# Public site URL (no trailing slash) — required on Vercel
NEXT_PUBLIC_SITE_URL=https://raxin-shop-r4aj.vercel.app

# Supabase (REQUIRED for production on Vercel)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin panel (/hajiasal/admin)
ADMIN_PASSWORD=change_me_strong_password

# Customer auth (required in production)
AUTH_SESSION_SECRET=change_me_long_random_secret_min_32_chars

# Test OTP — development/preview ONLY (do not set in production)
AUTH_TEST_PHONE=09123456789
AUTH_TEST_OTP=1234

# SMS (required for real OTP in production)
SMS_PROVIDER=kavenegar
SMS_API_KEY=
SMS_SENDER=

# Payment gateway (optional — COD works without this)
ZARINPAL_MERCHANT_ID=

# Seller panel demo (/hajiasal/seller)
# Phones: 09121111111 or 09122222222 | password: seller123
SELLER_DEMO_PASSWORD=seller123

# Optional: rate limiting
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
